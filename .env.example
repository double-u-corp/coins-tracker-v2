# Postgres connection string used by Prisma. Get this from your Postgres
# provider (Vercel Postgres via Neon, or Neon/Supabase directly — see
# README § Deployment: Postgres, not SQLite for setup steps). Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:12345678@host:5432/postgres?schema=public"

# Shared secret required in the Authorization header of /api/cron requests.
# Triggered by the GitHub Actions workflow in .github/workflows/cron.yml
# (see README § Cron Schedule & Timezone) — set the same value there as the
# CRON_SECRET repository secret.
CRON_SECRET="a3f912d1e4b7f8a9d0d2e3f4a5b6c7d8e9f0a1b2c4d4e5f6a7b8c9d0e1f2a3b4"

# Single-user login credentials, gating the Buy page, Manage Coins page, and
# the "Run Cron Now" button. Change these before deploying anywhere public.
AUTH_USERNAME="admin"
AUTH_PASSWORD="windows8"

# Secret used to sign the session cookie. Generate one with:
#   openssl rand -hex 32
AUTH_SECRET="b1c2d3e4f5a6b7c8d9e0f1a2b3c2d5e6f7a8b990d1e2f3a4b5c6d7e8f9a0b1c2"
